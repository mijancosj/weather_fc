# Copy to .env and fill in. Loaded via pydantic-settings (env_prefix="BACKEND_").
# Also copy the .env.example in each data-services/* package — the backend
# imports those clients directly and they read their own env vars.

BACKEND_DATABASE_URL=postgresql+asyncpg://price_discovery:price_discovery@localhost:5432/price_discovery

