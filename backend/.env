# Loaded via pydantic-settings (env_prefix="BACKEND_"). Filled with local-dev
# defaults so a fresh clone runs immediately after `scripts/db-setup` — no
# copying from a separate .env.example needed. Also fill in the .env in each
# data-services/* package — the backend imports those clients directly and
# they read their own env vars.
#
# IMPORTANT: after editing this file with anything real, run
# `git update-index --skip-worktree backend/.env` so your local edits are
# never picked up by `git status`/`git add` and can't end up in a commit.

BACKEND_DATABASE_URL=postgresql+asyncpg://price_discovery:price_discovery@localhost:5432/price_discovery

# BACKEND_ENVIRONMENT=development
# BACKEND_CORS_ORIGINS=["http://localhost:5173"]
# BACKEND_REFRESH_INTERVAL_MINUTES=30

# ENTSO-E areas to refresh prices + generation-by-type for (EIC codes). GB is
# deliberately not here — ENTSO-E has no day-ahead/generation data for GB
# post-Brexit, confirmed against the live API; UK comes from Elexon instead.
# BACKEND_ENTSOE_AREAS=["10YFR-RTE------C","10YES-REE------0","10YPT-REN------W"]
# BACKEND_DEFAULT_ELEXON_PROVIDER=APX

# ESIOS indicators (beyond the day-ahead price, always refreshed) to track
# into indicator_observations. Empty by default — discover IDs via
# GET /api/v1/indicators/catalog or esios-retriever's list_indicators().
# BACKEND_ESIOS_INDICATOR_IDS=[]
