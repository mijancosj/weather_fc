# Loaded via pydantic-settings (env_prefix="ENTSOE_"). Filled with a dummy
# placeholder so a fresh clone sees the expected shape immediately.
#
# Required. This is a security token, not your website password — request one
# at https://transparency.entsoe.eu after logging in:
# My Account Settings > Web API Security Token.
ENTSOE_API_TOKEN=your-entsoe-api-token-here

# Optional overrides — defaults shown.
# ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api
# ENTSOE_REQUEST_TIMEOUT_SECONDS=30
# ENTSOE_MAX_RETRIES=3
# ENTSOE_CACHE_DIR=data/cache
# ENTSOE_CACHE_TTL_SECONDS=3600

# IMPORTANT: after pasting your real token above, run
# `git update-index --skip-worktree data-services/entsoe-retriever/.env`
# so your local edit is never picked up by `git status`/`git add`.
