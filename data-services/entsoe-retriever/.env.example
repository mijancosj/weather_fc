# Copy to .env and fill in. Loaded via pydantic-settings (env_prefix="ENTSOE_").

# Required. This is a security token, not your website password — request one
# at https://transparency.entsoe.eu after logging in:
# My Account Settings > Web API Security Token.
ENTSOE_API_TOKEN=

# Optional overrides — defaults shown.
# ENTSOE_BASE_URL=https://web-api.tp.entsoe.eu/api
# ENTSOE_REQUEST_TIMEOUT_SECONDS=30
# ENTSOE_MAX_RETRIES=3
# ENTSOE_CACHE_DIR=data/cache
# ENTSOE_CACHE_TTL_SECONDS=3600
