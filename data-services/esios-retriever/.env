# Loaded via pydantic-settings (env_prefix="ESIOS_"). Filled with a dummy
# placeholder so a fresh clone sees the expected shape immediately.
#
# Required. Request a personal token by emailing consultasios@ree.es with
# subject "Personal token request" — usually granted within ~24h, free.
ESIOS_API_TOKEN=your-esios-api-token-here

# Optional overrides — defaults shown.
# ESIOS_BASE_URL=https://api.esios.ree.es
# ESIOS_REQUEST_TIMEOUT_SECONDS=30
# ESIOS_MAX_RETRIES=3
# ESIOS_CACHE_DIR=data/cache
# ESIOS_CACHE_TTL_SECONDS=3600

# IMPORTANT: after pasting your real token above, run
# `git update-index --skip-worktree data-services/esios-retriever/.env`
# so your local edit is never picked up by `git status`/`git add`.
