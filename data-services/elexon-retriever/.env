# Loaded via pydantic-settings (env_prefix="ELEXON_"). Filled with the
# default shape so a fresh clone sees exactly what's optional.
#
# Optional — most Elexon Insights Solution endpoints are open, but a key raises
# your rate limit. Get one at https://bmrs.elexon.co.uk
ELEXON_API_KEY=

# Optional overrides — defaults shown.
# ELEXON_BASE_URL=https://data.elexon.co.uk/bmrs/api/v1
# ELEXON_REQUEST_TIMEOUT_SECONDS=30
# ELEXON_MAX_RETRIES=3
# ELEXON_CACHE_DIR=data/cache
# ELEXON_CACHE_TTL_SECONDS=3600

# IMPORTANT: if you add a real key above, run
# `git update-index --skip-worktree data-services/elexon-retriever/.env`
# so your local edit is never picked up by `git status`/`git add`.
