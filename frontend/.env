# Leave empty for local dev — the Vite proxy in vite.config.ts forwards
# relative /api calls to localhost:8000, so requests stay same-origin and
# never hit CORS. Only set this for a production build where the frontend
# and backend are on different origins (e.g. deployed on Vercel while the
# backend runs on Render) — then it must be an absolute URL, and the
# backend's BACKEND_CORS_ORIGINS must include this frontend's origin.
# Not sensitive — safe to commit as-is. In Vercel, set the real production
# value as a project environment variable rather than editing this file.
VITE_API_BASE_URL=
